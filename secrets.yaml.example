# bomi configuration example
#
# Copy this file to the global config location and fill in your values:
#   macOS: ~/Library/Application Support/bomi/config.yaml
#   Linux: ~/.local/share/bomi/config.yaml
#
# Environment variables override config file values.
# Each key maps to BOMI_<KEY_UPPERCASE>, e.g.:
#   export BOMI_OPENROUTER_API_KEY=sk-or-v1-...

# Required only for `bomi analyze` and `bomi datasheet --summary`.
# Get a key at https://openrouter.ai/
openrouter_api_key: sk-or-v1-...
