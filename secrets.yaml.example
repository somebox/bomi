# jlcpcb-tool configuration example
#
# Copy this file to the global config location and fill in your values:
#   macOS: ~/Library/Application Support/jlcpcb/config.yaml
#   Linux: ~/.local/share/jlcpcb/config.yaml
#
# Environment variables override config file values.
# Each key maps to JLCPCB_<KEY_UPPERCASE>, e.g.:
#   export JLCPCB_OPENROUTER_API_KEY=sk-or-v1-...

# Required only for `jlcpcb analyze` and `jlcpcb datasheet --summary`.
# Get a key at https://openrouter.ai/
openrouter_api_key: sk-or-v1-...
